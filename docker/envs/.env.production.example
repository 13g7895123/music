# ============================================================
# YouTube Loop Player — 正式環境設定範例
# 複製並重命名為 .env.production（僅在伺服器上執行，勿 commit）：
#   cp docker/envs/.env.production.example docker/envs/.env.production
#
# ⚠️  所有標示「changeme」的值，deploy.sh 首次執行時會自動
#     替換為 16 碼隨機密碼。亦可手動修改後再執行部署。
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_ENV=production
APP_PORT=80
APP_BASEURL=https://your-domain.com/
APP_FORCE_HTTPS=true

# ─── Database（MariaDB）─────────────────────────────────────
DB_NAME=free_youtube
DB_USER=app_user
# ⚠️ deploy.sh 偵測到 changeme 時自動產生隨機密碼
DB_PASS=changeme
MYSQL_ROOT_PASSWORD=changeme_root
# 正式環境建議綁定 127.0.0.1，限制只有本機可直連
DB_PORT_EXPOSED=127.0.0.1:3307

# ─── Authentication ─────────────────────────────────────────
AUTH_MODE=line
MOCK_USER_ID=1

# ─── LINE Login（必填）──────────────────────────────────────
# 從 https://developers.line.biz/console/ 取得
LINE_LOGIN_CHANNEL_ID=your_channel_id_here
LINE_LOGIN_CHANNEL_SECRET=your_channel_secret_here
LINE_LOGIN_CALLBACK_URL=https://your-domain.com/api/auth/line/callback
TOKEN_EXPIRE_SECONDS=2592000
FRONTEND_URL=https://your-domain.com

# ─── JWT ─────────────────────────────────────────────────────
# ⚠️ deploy.sh 偵測到 changeme 時自動產生隨機密碼
# 亦可手動：openssl rand -base64 32
JWT_SECRET_KEY=changeme
JWT_ACCESS_TOKEN_EXPIRE=3600
JWT_REFRESH_TOKEN_EXPIRE=2592000

# ─── Cookie ──────────────────────────────────────────────────
# 格式：.your-domain.com（前面加點以支援子域名）
COOKIE_DOMAIN=.your-domain.com

# ─── phpMyAdmin ──────────────────────────────────────────────
# phpMyAdmin 獨立 port 運行，透過 NPM 子域名反向代理存取
# ⚠️ 建議用防火牆（ufw / iptables）限制 PMA_PORT 只允許 NPM 主機 IP 存取
PMA_PORT=8081
PMA_ABSOLUTE_URI=https://pma.your-domain.com/

# ─── Misc ────────────────────────────────────────────────────
TZ=Asia/Taipei
