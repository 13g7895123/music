# ============================================================
# YouTube Loop Player — 開發環境設定範例
# 複製並重命名為 .env.development：
#   cp docker/envs/.env.development.example docker/envs/.env.development
# ============================================================

# ─── Application ────────────────────────────────────────────
APP_ENV=development
APP_PORT=80
APP_BASEURL=http://localhost/
APP_FORCE_HTTPS=false

# ─── Database（MariaDB）─────────────────────────────────────
DB_NAME=free_youtube
DB_USER=app_user
DB_PASS=changeme
MYSQL_ROOT_PASSWORD=changeme_root
# 開發環境可公開 host port，格式：3307 或 0.0.0.0:3307
DB_PORT_EXPOSED=3307

# ─── Authentication ─────────────────────────────────────────
# 開發環境建議使用 mock，無需設定 LINE Login
AUTH_MODE=mock
MOCK_USER_ID=1

# ─── LINE Login（AUTH_MODE=line 時必填）──────────────────────
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=http://localhost/api/auth/line/callback
TOKEN_EXPIRE_SECONDS=2592000
FRONTEND_URL=http://localhost

# ─── JWT ─────────────────────────────────────────────────────
# deploy.sh 會自動替換 changeme 為隨機安全值
JWT_SECRET_KEY=changeme
JWT_ACCESS_TOKEN_EXPIRE=3600
JWT_REFRESH_TOKEN_EXPIRE=2592000

# ─── Cookie ──────────────────────────────────────────────────
COOKIE_DOMAIN=

# ─── Misc ────────────────────────────────────────────────────
TZ=Asia/Taipei
